<Window
    x:Class="BelarusJourneyGame.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BelarusJourneyGame"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.Resources>
            <Storyboard x:Name="ProgressBarAnimation">
                <DoubleAnimation
                    x:Name="BarAnimation"
                    Storyboard.TargetName="ExperienceBar"
                    Storyboard.TargetProperty="Value"
                    Duration="0:0:0.5"
                    EnableDependentAnimation="True">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="EventAppearanceAnimation">
                <DoubleAnimation
        Storyboard.TargetName="EventCard"
        Storyboard.TargetProperty="Opacity"
        From="0" To="1"
        Duration="0:0:0.4"/>

                <DoubleAnimation
        Storyboard.TargetName="EventCardTransform"
        Storyboard.TargetProperty="Y"
        From="20" To="0"
        Duration="0:0:0.4">
                    <DoubleAnimation.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="3"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>
        <Grid x:Name="MenuOverlay" Canvas.ZIndex="10">
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFB22222" Offset="0.0"/>
                        <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                        <GradientStop Color="#FF2E8B57" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="50">
                <StackPanel Spacing="5">
                    <TextBlock Text="БЕЛАРУСЬ" FontSize="90" FontWeight="Black" HorizontalAlignment="Center" Foreground="White" CharacterSpacing="150"/>
                    <TextBlock Text="ВЕЛИКОЕ ПУТЕШЕСТВИЕ" FontSize="22" FontWeight="Light" HorizontalAlignment="Center" Foreground="White" Opacity="0.9" CharacterSpacing="600"/>
                </StackPanel>
                <Button Click="StartGame_Click" Padding="60,25" Style="{StaticResource AccentButtonStyle}" CornerRadius="40" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <FontIcon Glyph="&#xF5B0;" Foreground="White"/>
                        <TextBlock Text="НАЧАТЬ ПУТЕШЕСТВИЕ" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="MainGameArea" Visibility="Collapsed">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF0D0D0D" Offset="0.0"/>
                    <GradientStop Color="#FF1A2A20" Offset="0.5"/>
                    <GradientStop Color="#FF0D1117" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="20" Background="#1AFFFFFF" CornerRadius="20" Padding="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="10,0,0,25">
                    <TextBlock Text="ВАШ СТАТУС" FontSize="10" FontWeight="Bold" Foreground="White" Opacity="0.5" CharacterSpacing="100"/>
                    <TextBlock Text="{x:Bind ViewModel.PlayerRank, Mode=OneWay}" FontSize="22" FontWeight="Black" Foreground="Gold"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="МАРШРУТ" FontWeight="Bold" Foreground="White" Opacity="0.5" Margin="10,0,0,10" CharacterSpacing="100"/>

                <ListView Grid.Row="2" 
                          ItemsSource="{x:Bind ViewModel.Regions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedRegion, Mode=TwoWay}"
                          SelectionChanged="RegionsList_SelectionChanged" 
                          Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:Region">
                            <Grid Padding="8" CornerRadius="8" 
              Opacity="{x:Bind local:MainWindow.ProgressToOpacity(ExplorationProgress), Mode=OneWay}">

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE73E;" 
                          Foreground="LawnGreen" 
                          FontSize="14" 
                          VerticalAlignment="Center"
                          Visibility="{x:Bind local:MainWindow.ConvertProgressToVisibility(ExplorationProgress), Mode=OneWay}"/>

                                    <StackPanel>
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="White"/>

                                        <TextBlock Text="{x:Bind local:MainWindow.ProgressToStatusText(ExplorationProgress), Mode=OneWay}"
                               FontSize="10" 
                               FontWeight="Black"
                               Foreground="{x:Bind local:MainWindow.ProgressToStatusColor(ExplorationProgress), Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="3" Margin="0,15,0,0">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Click="SaveGame_Click" Margin="0,0,5,0" HorizontalAlignment="Stretch" CornerRadius="15" Background="#1AFFFFFF" BorderThickness="1" BorderBrush="#33FFFFFF">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="СОХРАНИТЬ" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Click="LoadGame_Click" Margin="5,0,0,0" HorizontalAlignment="Stretch" CornerRadius="15" Background="#1AFFFFFF" BorderThickness="1" BorderBrush="#33FFFFFF">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B5;" FontSize="14" Foreground="White"/>
                                    <TextBlock Text="ЗАГРУЗИТЬ" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Button Click="ExitButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="0" CornerRadius="15" BorderThickness="0">
                            <Grid Height="45">
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#CCB22222" Offset="0.0"/>
                                        <GradientStop Color="#66B22222" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <TextBlock Text="ПРЕРВАТЬ ПУТЬ" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="1" Padding="0,30,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="{x:Bind ViewModel.SelectedRegion.Name, Mode=OneWay}" FontSize="42" FontWeight="Black" Foreground="White"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="{x:Bind ViewModel.SelectedRegion.ExplorationProgress, Mode=OneWay}" FontSize="32" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text="%" FontSize="18" Foreground="White" Margin="4,0,0,6" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,5,0,20">
                    <TextBlock Text="ИССЛЕДОВАНИЕ ОБЛАСТИ" FontSize="10" FontWeight="Bold" Foreground="LawnGreen" Opacity="0.8" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="ExperienceBar"
             Value="{x:Bind ViewModel.SelectedRegion.ExplorationProgress, Mode=OneWay}" 
             Maximum="100" 
             Height="10" 
             CornerRadius="5" 
             Background="#33FFFFFF" 
             Foreground="LawnGreen"
                                 Opacity="0.9"/>

                    <Grid Margin="0,15,0,0">
                        <TextBlock Text="ЗАПАС ТОПЛИВА" FontSize="10" FontWeight="Bold" Foreground="Orange" Opacity="0.8"/>
                        <TextBlock Text="{x:Bind ViewModel.Energy, Mode=OneWay}" FontSize="10" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{x:Bind ViewModel.Energy, Mode=OneWay}" 
                 Maximum="100" 
                 Height="6" 
                 CornerRadius="3" 
                 Background="#33FFFFFF" 
                 Foreground="Orange"
                 Margin="0,5,0,0"/>

                    <Button Click="RestButton_Click" HorizontalAlignment="Right" Margin="0,10,0,0" Style="{StaticResource DefaultButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE708;" FontSize="14"/>
                            <TextBlock Text="Сделать привал"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <WebView2 x:Name="MapWebView" 
          Grid.Row="2" 
          HorizontalAlignment="Stretch" 
          VerticalAlignment="Stretch"
          Margin="0,0,0,0"
          DefaultBackgroundColor="Black"/>

                <Grid Grid.Row="3" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="20">
                        <Border Background="#1AFFFFFF" 
                Padding="25" 
                CornerRadius="16" 
                BorderThickness="1" 
                BorderBrush="#22FFFFFF">
                            <StackPanel Spacing="10">
                                <TextBlock Text="О ЛОКАЦИИ" FontSize="10" FontWeight="Bold" Foreground="LawnGreen" Opacity="0.8" CharacterSpacing="120"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentRegionDescription, Mode=OneWay}"
                           TextWrapping="Wrap" 
                           FontSize="16" 
                           Foreground="#EEEEEE" 
                           LineHeight="24"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="EventCard" CornerRadius="16" BorderThickness="1" BorderBrush="#33FFFFFF">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="EventCardTransform" Y="0"/>
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E6000000" Offset="0.0"/>
                                    <GradientStop Color="#E61A1A1A" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="16,0,0,16" 
                Background="{ThemeResource SystemAccentColor}" VerticalAlignment="Stretch"/>

                                <Grid Grid.Column="1" Padding="20,15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                                        <FontIcon Glyph="&#xE946;" Foreground="Gold" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="ПОСЛЕДНИЕ СОБЫТИЯ" FontSize="11" FontWeight="Bold" Foreground="Gold" Opacity="0.9" CharacterSpacing="150"/>
                                    </StackPanel>

									<TextBlock x:Name="EventTextBlock"
											   Grid.Row="1"
											   Text="{x:Bind ViewModel.CurrentEvent, Mode=OneWay}"
											   FontSize="18"
											   FontStyle="Italic"
											   Foreground="White"
											   TextWrapping="Wrap"
											   MinHeight="60"
											   VerticalAlignment="Center">
                                        <TextBlock.Transitions>
                                            <TransitionCollection>
                                                <RepositionThemeTransition/>
                                            </TransitionCollection>
                                        </TextBlock.Transitions>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
        <Canvas x:Name="ConfettiCanvas" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</Window>